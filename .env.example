# ===========================================
# CodeGate Configuration
# Copy this file to .env and fill in your values
# ===========================================

# LLM Provider Configuration
# LiteLLM supports: openai, anthropic, deepseek, ollama, etc.
# See: https://docs.litellm.ai/docs/providers

# Model for Spec Council (needs strong reasoning)
CODEGATE_SPEC_MODEL=deepseek/deepseek-chat

# Model for Code Executor (needs good code generation)
CODEGATE_EXEC_MODEL=deepseek/deepseek-chat

# Model for Review Gate (needs careful comparison)
CODEGATE_REVIEW_MODEL=deepseek/deepseek-chat

# Model for Gatekeeper (structured decision)
CODEGATE_GATE_MODEL=deepseek/deepseek-chat

# Model for Benchmark Evaluator (LLM-as-Judge)
CODEGATE_EVAL_MODEL=deepseek/deepseek-chat

# API Keys (fill in the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional: Custom API base URL (for proxies or local models)
# OPENAI_API_BASE=https://your-proxy.com/v1

# Gemini CLI Configuration (if using --executor gemini)
# Install: npm install -g @google/gemini-cli
# Auth: run `gemini` once to login with Google account
# Or set API key: GOOGLE_API_KEY=your-api-key

# Artifact Storage
CODEGATE_STORE_DIR=./artifacts

# Max clarification rounds in Spec Council
CODEGATE_MAX_CLARIFY_ROUNDS=3

# Logging level
CODEGATE_LOG_LEVEL=INFO
